# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Financial API Keys for StockLens
FRED_API_KEY="YOUR_FRED_API_KEY_HERE"

# Alpha Vantage — secondary market-data provider used as an automatic fallback
# when Yahoo Finance is unavailable. Free key: https://www.alphavantage.co/support/#api-key
# (free tier is rate limited, so it is only hit when the Yahoo layer fails)
ALPHAVANTAGE_API_KEY="YOUR_ALPHAVANTAGE_API_KEY_HERE"


